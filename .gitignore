# =============================================================================
# .gitignore — Portfolio site (allandabre.com)
# =============================================================================
# Dependencies, build output, secrets, IDE/OS noise. Keep repo deploy-safe.
# =============================================================================

# Secrets & environment — never commit
.env
.env.*
!.env.example

# Dependencies & build
node_modules/
dist/
dist-ssr/
.vite/
*.tsbuildinfo

# Local / machine-only overrides
*.local

# Sensitive or generated assets (keep out of Git if policy requires)
*.pdf

# AI tooling
.claude/
.cursor/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Vercel CLI local project link
.vercel/

# Windows reserved / junk
nul
_ul
Thumbs.db

# macOS
.DS_Store

# Editors / IDEs
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
